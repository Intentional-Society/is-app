# Production environment variables — reference for Vercel dashboard setup.
# Local developers do not use this file: run `npm run setup` to generate
# `.env.local` with the deterministic local Supabase defaults.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key
# Secret (service-role) key — server-only, bypasses RLS. Required by the
# server admin client (src/lib/supabase/admin.ts) and operator scripts
# such as scripts/import-members-csv.ts (auth Admin API + Storage uploads).
SUPABASE_SECRET_KEY=sb_secret_...

# Database (Supabase Transaction Pooler — required for serverless and IPv4)
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o123456.ingest.us.sentry.io/1234567
SENTRY_DSN=https://your-dsn@o123456.ingest.us.sentry.io/1234567
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project

# Supabase Management API (used by scripts/update-email-templates.mjs
# and any future operator scripts that hit api.supabase.com). Personal
# access token, account-scoped — generate at
# https://supabase.com/dashboard/account/tokens. Treat as temporary:
# create .env.prod with this set, run the script, delete the file.
# Account-wide blast radius if leaked — see docs/doc-supabase.md.
SUPABASE_ACCESS_TOKEN=sbp_...

# Buttondown — operator-only, never set in Vercel. Scoped to the
# `api-tests` newsletter (Buttondown keys are per-newsletter, so the
# key is structurally incapable of touching any other audience). Used
# by scripts/buttondown-recording/seed-fixtures.ts and the
# tests/manual/buttondown-api-golds.test.ts recorder. See
# docs/design-buttondown.md Appendix A.
BUTTONDOWN_TEST_API_KEY=
# Optional. Pinned API version label (Buttondown uses dated versions),
# stamped into golds/meta.json on each recording. Defaults to "unknown"
# if unset. Not a secret.
BUTTONDOWN_TEST_API_VERSION=2026-04-01
