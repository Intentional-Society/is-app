# claude — ignore everything in .claude/ EXCEPT shared team files: the
# project-scoped settings (PostToolUse hook config) and the hook scripts
# the settings reference. Per-developer state (`.claude/settings.local.json`)
# stays ignored.
.claude/*
!.claude/settings.json
!.claude/hooks/
.vercel

# agent scratch notes — emergent design decisions, working memory
.scratch/

# member-import source data — contains member PII, never commit
scripts/*.csv
scripts/.import-cache/
scripts/.import-logs/
