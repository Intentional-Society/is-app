{
  "name": "is-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "update_main_branch_protection": "node scripts/update-main-branch-protection.mjs",
    "dev": "npm run dev:db && next dev",
    "dev:db": "node scripts/check-env.mjs && node scripts/ensure-docker.mjs && node scripts/ensure-supabase.mjs && node scripts/migrate.mjs && node scripts/seed-e2e-users.mjs",
    "dev:db:stop": "npx supabase stop",
    "dev:db:reset": "npx supabase db reset && npx drizzle-kit migrate",
    "prod:db:expand": "node scripts/forward-migrate-prod-schema-expansion.mjs",
    "seed:dev": "npx tsx scripts/seed-dev.ts",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome check --write .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "npm run lint && npm run typecheck && npm run dev:db && vitest run && playwright test",
    "test:functional": "npm run dev:db && vitest run",
    "test:functional:server": "npm run dev:db && vitest run --project functional-server",
    "test:functional:client": "vitest run --project functional-client",
    "watch": "npm run dev:db && vitest",
    "test:e2e": "npm run dev:db && playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hono/node-server": "^2.0.2",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-force": "^3.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.19",
    "lucide-react": "^1.16.0",
    "next": "^16.2.5",
    "next-axiom": "^1.10.0",
    "postgres": "^3.4.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-easy-crop": "^5.5.7",
    "react-joyride": "^3.1.0",
    "shadcn": "^4.7.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "supabase": "^2.98.2",
    "tailwindcss": "^4",
    "typescript": "^6.0",
    "vitest": "^4.1.6"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-darwin-arm64": "^4.2.2"
  }
}
