{
  "name": "is-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:db && next dev",
    "dev:db": "npx supabase status || npx supabase start && (npx drizzle-kit migrate || true)",
    "dev:db:stop": "npx supabase stop",
    "dev:db:reset": "npx supabase db reset && npx drizzle-kit migrate",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run && playwright test",
    "test:functional": "vitest run",
    "watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.96.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "next": "^15.3",
    "next-axiom": "^1.10.0",
    "postgres": "^3.4.8",
    "react": "^19.1",
    "react-dom": "^19.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^15.3",
    "supabase": "^2.85.0",
    "tailwindcss": "^4",
    "typescript": "^5.8",
    "vitest": "^4.1.2"
  }
}
