{
  "name": "is-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "update_main_branch_protection": "node scripts/update-main-branch-protection.mjs",
    "dev": "npm run dev:db && next dev",
    "dev:db": "node scripts/check-env.mjs && node scripts/ensure-docker.mjs && node scripts/ensure-supabase.mjs && node scripts/migrate.mjs && node scripts/seed-e2e-users.mjs",
    "dev:db:stop": "npx supabase stop",
    "dev:db:reset": "npx supabase db reset && npx drizzle-kit migrate",
    "seed:dev": "npx tsx scripts/seed-dev.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "npm run dev:db && vitest run && playwright test",
    "test:functional": "npm run dev:db && vitest run",
    "watch": "npm run dev:db && vitest",
    "test:e2e": "npm run dev:db && playwright test"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@sentry/nextjs": "^10.49.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.104.0",
    "@tanstack/react-query": "^5.99.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "next": "^15.3",
    "next-axiom": "^1.10.0",
    "postgres": "^3.4.8",
    "react": "^19.1",
    "react-dom": "^19.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^15.3",
    "supabase": "^2.93.0",
    "tailwindcss": "^4",
    "typescript": "^6.0",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-darwin-arm64": "^4.2.2"
  }
}
