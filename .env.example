# Supabase
# For local dev (after `npm run dev:db` or `npx supabase start`):
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<from supabase start output>
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key

# Database (Supabase Transaction Pooler — required for serverless and IPv4)
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o123456.ingest.us.sentry.io/1234567
SENTRY_DSN=https://your-dsn@o123456.ingest.us.sentry.io/1234567
# Source maps (set in CI/Vercel, not needed locally):
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
